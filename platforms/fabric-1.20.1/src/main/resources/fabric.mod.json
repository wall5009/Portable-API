{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": ["${mod_authors}"],
  "license": "${mod_license}",
  "environment": "*",
  "entrypoints": {
    "main": ["dev.portablemc.internal.platform.fabric1201.PortableFabric1201"],
    "client": ["dev.portablemc.internal.platform.fabric1201.PortableFabric1201Client"]
  },
  "depends": {
    "fabricloader": ">=${fabric_loader}",
    "minecraft": "${minecraft_version}",
    "fabric-api": ">=${fabric_api}"
  },
  "custom": {
    "portable-api:loader": "${loader}",
    "portable-api:minecraft": "${minecraft_version}"
  }
}
