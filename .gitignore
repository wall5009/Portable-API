# Gradle
.gradle/
build/
**/build/
!gradle/wrapper/gradle-wrapper.jar

# Minecraft development run directories are generated and can contain account
# cache files, downloaded assets, crash reports, and local options.
run/
runs/
**/run/
**/runs/

# IntelliJ IDEA: keep project metadata and shared run configurations, ignore
# workspace state and machine-local caches.
.idea/*
!.idea/runConfigurations/
!.idea/runConfigurations/*.xml
.idea/workspace.xml
.idea/tasks.xml
.idea/shelf/
.idea/httpRequests/
.idea/dataSources/
.idea/dataSources.local.xml
*.iml
out/

# OS/editor noise
.DS_Store
Thumbs.db
*.swp
*.swo

# Release secrets and local publishing overrides
.env
local.properties
gradle-local.properties
